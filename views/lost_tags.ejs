<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ON Sistema — Tags Perdidos · <%= clientName %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root{--bg:#0e1117;--surface:#161b22;--surface-2:#1c2333;--border:rgba(255,255,255,0.07);--border-focus:rgba(62,207,142,0.35);--green:#3ecf8e;--green-dim:rgba(62,207,142,0.10);--green-glow:rgba(62,207,142,0.22);--red:#ef4444;--red-dim:rgba(239,68,68,0.10);--amber:#f59e0b;--amber-dim:rgba(245,158,11,0.10);--text:#ededef;--text-2:#8b8fa8;--text-3:#4a4f62;--radius:13px;}
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:28px 20px;padding-top:92px;background-image:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(245,158,11,0.05) 0%,transparent 100%);}
        .navbar{position:fixed;top:0;left:0;right:0;height:64px;background:rgba(14,17,23,0.80);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;z-index:1000;}
        .brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
        .nav-logo{width:34px;height:34px;background:linear-gradient(135deg,var(--green),#22c55e);border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#0a1008;box-shadow:0 0 18px var(--green-glow);flex-shrink:0;}
        .brand-text{display:flex;flex-direction:column;gap:1px;}
        .brand-name{font-size:14px;font-weight:700;color:var(--text);letter-spacing:-0.3px;line-height:1;}
        .brand-sub{font-size:10px;font-weight:500;color:var(--text-3);letter-spacing:0.4px;text-transform:uppercase;}
        .nav-links{display:flex;gap:6px;align-items:center;}
        .nav-link{padding:6px 14px;font-size:13px;font-weight:500;text-decoration:none;border-radius:8px;border:1px solid transparent;color:var(--text-2);transition:all 0.15s;}
        .nav-link:hover{background:var(--surface);color:var(--text);border-color:var(--border);}
        .nav-link.active{background:var(--amber-dim);color:var(--amber);border-color:rgba(245,158,11,0.18);}
        .container{max-width:900px;margin:0 auto;}
        .page-header{text-align:center;margin-bottom:28px;animation:fadeUp 0.4s ease both;}
        .page-title{font-size:32px;font-weight:800;letter-spacing:-1.2px;margin-bottom:8px;background:linear-gradient(135deg,#fff 20%,var(--amber) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
        .page-subtitle{font-size:14px;color:var(--text-2);}
        .card{background:rgba(22,27,34,0.75);border:1px solid var(--border);border-radius:18px;padding:24px;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);}
        .card+.card{margin-top:14px;}
        .card-header{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:18px;}
        .card-title{font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.8px;}
        .filter-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
        .filter-label{font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.7px;white-space:nowrap;}
        input[type="text"],input[type="number"]{padding:8px 12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-family:'Inter',sans-serif;font-size:13px;color:var(--text);transition:border-color 0.2s;}
        input[type="text"]:focus,input[type="number"]:focus{outline:none;border-color:var(--border-focus);}
        input[type="number"]{width:80px;}
        .btn-go{padding:8px 18px;font-size:13px;font-weight:700;background:var(--amber);color:#0a0800;border:none;border-radius:var(--radius);cursor:pointer;transition:all 0.15s;}
        .btn-go:hover{background:#fbbf24;transform:translateY(-1px);}
        .btn-action{padding:6px 14px;font-size:12px;font-weight:600;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text-2);cursor:pointer;transition:all 0.15s;}
        .btn-action:hover{color:var(--text);border-color:rgba(255,255,255,0.12);}
        .client-badge{display:inline-flex;align-items:center;gap:8px;background:var(--amber-dim);border:1px solid rgba(245,158,11,0.18);border-radius:20px;padding:4px 14px 4px 10px;font-size:13px;font-weight:600;color:var(--amber);margin-bottom:16px;}
        .client-dot{width:6px;height:6px;border-radius:50%;background:var(--amber);}
        .stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:4px;}
        .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;text-align:center;}
        .stat-value{font-size:32px;font-weight:800;letter-spacing:-1px;color:var(--amber);margin-bottom:4px;}
        .stat-label{font-size:10px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.7px;}
        .article-section{margin-bottom:20px;}
        .article-title{font-size:11px;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border);}
        .tag-table{width:100%;border-collapse:collapse;}
        .tag-table th{padding:8px 12px;text-align:left;font-size:10px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.7px;border-bottom:1px solid var(--border);}
        .tag-table td{padding:10px 12px;font-size:12px;border-bottom:1px solid rgba(255,255,255,0.03);color:var(--text-2);}
        .tag-table tr:last-child td{border-bottom:none;}
        .tag-table tr:hover td{background:rgba(255,255,255,0.02);color:var(--text);}
        .epc-mono{font-family:monospace;font-size:11px;color:var(--green);}
        .days-ago{font-weight:600;color:var(--amber);}
        .status-pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600;background:var(--surface-2);color:var(--text-3);}
        .empty-state{text-align:center;padding:40px;font-size:14px;color:var(--green);}
        .alert-error{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);color:#f87171;border-radius:var(--radius);padding:14px 18px;font-size:13px;}
        @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
        .nav-toggle{display:none;background:none;border:1px solid var(--border);border-radius:8px;padding:7px 9px;cursor:pointer;color:var(--text-2);flex-direction:column;gap:4px;transition:background 0.15s,color 0.15s;flex-shrink:0;}
        .nav-toggle:hover{background:var(--surface);color:var(--text);}
        .nav-toggle span{display:block;width:18px;height:1.5px;background:currentColor;border-radius:2px;transition:transform 0.22s ease,opacity 0.15s;}
        .nav-toggle.open span:nth-child(1){transform:translateY(5.5px) rotate(45deg);}
        .nav-toggle.open span:nth-child(2){opacity:0;transform:scaleX(0);}
        .nav-toggle.open span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg);}
        @media(max-width:780px){.nav-toggle{display:flex;}.nav-links{display:none;position:fixed;top:64px;left:0;right:0;background:rgba(10,13,18,0.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:10px 16px 16px;flex-direction:column;gap:4px;z-index:999;}.nav-links.open{display:flex;animation:slideDown 0.18s ease;}.nav-link{padding:10px 14px;width:100%;}}
        @keyframes slideDown{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
    </style>
</head>
<body>
<nav class="navbar">
    <a class="brand" href="/"><div class="nav-logo">ON</div><div class="brand-text"><span class="brand-name">Sistema de Inventario</span><span class="brand-sub">Tags Perdidos</span></div></a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <div class="nav-links" id="navLinks">
        <a class="nav-link" href="/">Conteo en Vivo</a>
        <a class="nav-link" href="/dar-de-alta">Dar de Alta</a>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/compare">Comparar</a>
        <a class="nav-link" href="/tag-history">Historial Tag</a>
        <a class="nav-link" href="/batch-status">Corrector</a>
        <a class="nav-link" href="/logout" style="color:var(--text-3);">Salir</a>
    </div>
</nav>

<div class="container">
    <div class="page-header">
        <h1 class="page-title">Tags Perdidos / AWOL</h1>
        <p class="page-subtitle">Prendas sin actividad reciente que no están en estado Entregado</p>
    </div>

    <!-- Filter form -->
    <div class="card" style="animation:fadeUp 0.4s ease both;">
        <div class="card-header"><span class="card-title">Filtrar</span></div>
        <form method="GET" action="/lost-tags">
            <div class="filter-row">
                <span class="filter-label">Cliente:</span>
                <input type="text" name="client" value="<%= clientName %>" placeholder="Nombre del cliente" required />
                <span class="filter-label">Sin actividad por más de</span>
                <input type="number" name="days" value="<%= days %>" min="1" max="365" />
                <span class="filter-label">días</span>
                <button type="submit" class="btn-go">Buscar →</button>
            </div>
        </form>
    </div>

    <% if (error) { %>
        <div class="alert-error" style="margin-top:14px;"><%= error %></div>
    <% } else if (total === 0) { %>
        <div class="card" style="animation:fadeUp 0.4s 0.05s ease both;margin-top:14px;">
            <div class="empty-state">✓ Sin prendas perdidas en los últimos <%= days %> días para <strong><%= clientName %></strong></div>
        </div>
    <% } else { %>

    <!-- Summary -->
    <div class="card" style="animation:fadeUp 0.4s 0.05s ease both;margin-top:14px;">
        <div class="client-badge"><span class="client-dot"></span><%= clientName %></div>
        <div class="stat-row">
            <div class="stat-card"><div class="stat-value"><%= total %></div><div class="stat-label">Tags sin actividad</div></div>
            <div class="stat-card"><div class="stat-value" style="font-size:24px;"><%= days %></div><div class="stat-label">Días de corte</div></div>
            <div class="stat-card"><div class="stat-value" style="font-size:24px;"><%= Object.keys(byArticle).length %></div><div class="stat-label">Artículos afectados</div></div>
        </div>
    </div>

    <!-- Breakdown by article -->
    <div class="card" style="animation:fadeUp 0.4s 0.09s ease both;margin-top:14px;">
        <div class="card-header">
            <span class="card-title">Desglose por artículo</span>
            <button id="exportCSV" class="btn-action">↓ CSV</button>
        </div>
        <% Object.entries(byArticle).forEach(([article, tags]) => { %>
        <div class="article-section">
            <div class="article-title"><%= article %> — <%= tags.length %> tag<%= tags.length > 1 ? 's' : '' %></div>
            <div style="overflow-x:auto;">
            <table class="tag-table">
                <thead><tr><th>EPC</th><th>Estado</th><th>Lavados</th><th>Última vista</th><th>Días inactivo</th></tr></thead>
                <tbody>
                    <% tags.forEach(tag => {
                        const daysSince = Math.floor((Date.now() - tag.last_seen) / (1000 * 60 * 60 * 24));
                    %>
                    <tr>
                        <td><a href="/tag-history?epc=<%= tag.scanId %>" class="epc-mono" style="text-decoration:none;"><%= tag.scanId %></a></td>
                        <td><span class="status-pill"><%= tag.status %></span></td>
                        <td><%= tag.wash_count || 0 %></td>
                        <td><%= new Date(tag.last_seen).toLocaleDateString('es-MX',{year:'numeric',month:'short',day:'numeric'}) %></td>
                        <td><span class="days-ago"><%= daysSince %> días</span></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

<script>
const t=document.getElementById('navToggle'),n=document.getElementById('navLinks');
t.addEventListener('click',()=>{t.classList.toggle('open');n.classList.toggle('open');});
n.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',()=>{t.classList.remove('open');n.classList.remove('open');}));

const exportBtn = document.getElementById('exportCSV');
if (exportBtn) {
    const tagsData = <%- JSON.stringify(lostTags.map(t => ({ epc: t.scanId, article: t.article, status: t.status, washes: t.wash_count || 0, lastSeen: t.last_seen, daysSince: Math.floor((Date.now() - t.last_seen) / (1000*60*60*24)) }))) %>;
    exportBtn.addEventListener('click', () => {
        const rows = [['EPC','Artículo','Estado','Lavados','Última Vista','Días Inactivo']];
        tagsData.forEach(r => {
            const d = new Date(r.lastSeen).toLocaleDateString('es-MX');
            rows.push([r.epc, r.article||'', r.status||'', r.washes, d, r.daysSince]);
        });
        const blob = new Blob(['﻿' + rows.map(r => r.join(',')).join('\n')], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a'); link.href = URL.createObjectURL(blob);
        link.download = `tags-perdidos-<%= clientName %>.csv`; link.click();
    });
}
</script>
</body>
</html>
