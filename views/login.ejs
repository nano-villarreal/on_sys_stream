<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ON Sistema — Acceso</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0e1117; --surface: #161b22; --border: rgba(255,255,255,0.07);
            --border-focus: rgba(62,207,142,0.35); --green: #3ecf8e;
            --green-dim: rgba(62,207,142,0.10); --green-glow: rgba(62,207,142,0.22);
            --red: #ef4444; --text: #ededef; --text-2: #8b8fa8; --text-3: #4a4f62;
            --radius: 13px;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg); color: var(--text); min-height: 100vh;
            display: flex; align-items: center; justify-content: center; padding: 20px;
            background-image: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(62,207,142,0.07) 0%, transparent 100%);
        }
        .login-wrap { width: 100%; max-width: 380px; animation: fadeUp 0.4s ease both; }
        .brand {
            display: flex; align-items: center; gap: 12px; justify-content: center;
            margin-bottom: 36px; text-decoration: none;
        }
        .nav-logo {
            width: 42px; height: 42px;
            background: linear-gradient(135deg, var(--green), #22c55e);
            border-radius: 11px; display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 15px; color: #0a1008;
            box-shadow: 0 0 24px var(--green-glow);
        }
        .brand-name { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; }
        .card {
            background: rgba(22,27,34,0.80); border: 1px solid var(--border);
            border-radius: 20px; padding: 32px;
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        }
        .card-title { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 6px; }
        .card-sub { font-size: 13px; color: var(--text-2); margin-bottom: 28px; }
        .field-label { display: block; font-size: 11px; font-weight: 600; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
        input[type="password"] {
            width: 100%; padding: 12px 14px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); font-family: 'Inter', sans-serif;
            font-size: 14px; color: var(--text); transition: border-color 0.2s, box-shadow 0.2s;
            caret-color: var(--green); margin-bottom: 20px;
        }
        input[type="password"]:focus { outline: none; border-color: var(--border-focus); box-shadow: 0 0 0 3px rgba(62,207,142,0.07); }
        .btn-submit {
            width: 100%; padding: 13px; font-size: 14px; font-weight: 700;
            background: var(--green); color: #091a12;
            border: none; border-radius: var(--radius); cursor: pointer;
            box-shadow: 0 4px 16px var(--green-glow); transition: all 0.15s;
        }
        .btn-submit:hover { background: #4ddfaa; transform: translateY(-1px); }
        .alert-error {
            background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
            color: #f87171; border-radius: var(--radius); padding: 12px 16px;
            font-size: 13px; margin-bottom: 20px;
        }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="login-wrap">
        <a class="brand" href="/login">
            <div class="nav-logo">ON</div>
            <span class="brand-name">Sistema de Inventario</span>
        </a>
        <div class="card">
            <h1 class="card-title">Acceso</h1>
            <p class="card-sub">Ingresa la contraseña de administrador para continuar.</p>

            <% if (error) { %>
            <div class="alert-error"><%= error %></div>
            <% } %>

            <form method="POST" action="/login">
                <input type="hidden" name="next" value="<%= next %>" />
                <label class="field-label" for="password">Contraseña</label>
                <input type="password" id="password" name="password" placeholder="••••••••" autofocus required />
                <button type="submit" class="btn-submit">Entrar →</button>
            </form>
        </div>
    </div>
</body>
</html>
