        function renderTrend(selectedArt) {
            // Build sorted timeline: history + today
            const today = new Date().toISOString().slice(0, 10);
            const points = [...(data.history || [])];
            if (!points.find(p => p.date === today)) {
                points.push({ date: today, snapshot: data.current });
            }
            points.sort((a, b) => a.date.localeCompare(b.date));

            const labels   = points.map(p => {
                const d = new Date(p.date + 'T12:00:00');
                return d.toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
            });
            const datasets = activeCols.map(s => {
                const m = STATUS_META[s] || { label: s, color: '#9ca3af' };
                return {
                    label: m.label,
                    data:  points.map(p => (p.snapshot?.[selectedArt]?.[s]) || 0),
                    backgroundColor: m.color + 'bb',
                    borderColor:     m.color,
                    borderWidth: 1,
                };
            });

            const ctx = document.getElementById('articleTrendChart');
            if (trendChart) trendChart.destroy();
            trendChart = new Chart(ctx, {
                type: 'bar',
                data: { labels, datasets },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#8b8fa8', font: { size: 11 }, padding: 12, boxWidth: 10, boxHeight: 10 } },
                        tooltip: { callbacks: { label: c => `${c.dataset.label}: ${c.parsed.y}` } }
                    },
                    scales: {
                        x: { stacked: true, grid: { display: false }, ticks: { color: '#8b8fa8', font: { size: 10 }, maxRotation: 45 } },
                        y: { stacked: true, grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#8b8fa8', font: { size: 10 } }, beginAtZero: true }
                    }
                }
            });
        }

        function render() {
            labelEl.textContent  = dateLabel(dayOffset);
            nextBtn.disabled     = dayOffset >= 0;
            nextBtn.style.opacity = dayOffset >= 0 ? '0.35' : '1';
            renderTable(snapshotForOffset(dayOffset));
            renderTrend(artSel.value || (data.articles || [])[0]);
        }

        prevBtn.addEventListener('click', () => { dayOffset--; render(); });
        nextBtn.addEventListener('click', () => { if (dayOffset < 0) { dayOffset++; render(); } });
        artSel.addEventListener('change', () => renderTrend(artSel.value));

        card.style.display = 'block';
        loadEl.style.display   = 'none';
        contentEl.style.display = 'block';
        render();
    })();

    // ── Lifecycle threshold editor ────────────────────────────────────────────
    async function setThreshold(client, article) {
        const input = prompt(`Umbral de lavados para "${article}" (actual: 80):`, '80');
        if (!input) return;
        const threshold = parseInt(input);
        if (isNaN(threshold) || threshold < 1) return alert('Número inválido');
        try {
            const r = await fetch('/api/set-threshold', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ client, article, threshold })
            });
            if (r.ok) { alert(`Umbral actualizado a ${threshold} lavados. Recarga para ver cambios.`); }
            else { alert('Error al guardar'); }
        } catch(e) { alert('Error de red'); }
    }
    <% } %>
    </script>
</body>
</html>
