    // ── Per-article status breakdown ─────────────────────────────────────────
    (async function () {
        const STATUS_META = {
            'Entregado':         { label: 'Entregado',    color: '#3ecf8e' },
            'Recoleccion':       { label: 'Lavandería',   color: '#f59e0b' },
