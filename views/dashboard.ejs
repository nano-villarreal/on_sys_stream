        };

        let data = null;
        let dayOffset = 0;          // 0 = today, -1 = yesterday …
        let trendChart = null;

        const card      = document.getElementById('articleStatusCard');
        const loadEl    = document.getElementById('artStatusLoading');
        const contentEl = document.getElementById('artStatusContent');
        const tableEl   = document.getElementById('artStatusTable');
        const labelEl   = document.getElementById('artStatusDateLabel');
