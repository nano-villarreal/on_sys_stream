.tbl th.num,.tbl td.num{text-align:right;padding-right:0}
.tbl td{padding:6px 10px 6px 0;border-bottom:1px solid var(--b);color:var(--t2);font-size:11px}
.tbl td:first-child{color:var(--t);font-weight:500}
.tbl tr:last-child td{border-bottom:none}
.chart-box{position:relative;height:100%}
/* slide 3 */
.s3-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
.s3-kpi{background:var(--s);border:1px solid var(--b);border-radius:9px;padding:13px 16px}
.s3-kpi .v{font-size:22px;font-weight:800;color:var(--t)}
.s3-kpi .l{font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.6px;color:var(--t3);margin-top:3px}
.evt-tbl{width:100%;border-collapse:collapse;font-size:11px}
.evt-tbl th{text-align:left;font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--t3);padding:0 0 8px;border-bottom:1px solid var(--b)}
.evt-tbl td{padding:5px 8px 5px 0;border-bottom:1px solid var(--b);color:var(--t2);vertical-align:top}
.evt-tbl td.dt{white-space:nowrap;color:var(--t3);font-size:10px}
.evt-tbl td.num{text-align:right;white-space:nowrap}
.evt-tbl td.arts{max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.evt-tbl td.ent{color:var(--ac);font-weight:600;white-space:nowrap}
.evt-tbl td.rec{color:#60a5fa;font-weight:600;white-space:nowrap}
.evt-tbl tr:last-child td{border-bottom:none}
.rate{font-size:10px;color:var(--t2)}
.rate strong{color:var(--ac)}
</style></head><body>

<!-- Slide 1: Cover -->
<div class="slide">
  <div class="s1-top">
    <div class="logo">ON Sistema · Inventario RFID</div>
    <div class="gen">${esc(generated)}</div>
  </div>
  <div style="flex:1;display:flex;flex-direction:column;justify-content:center">
    <div class="accent-bar"></div>
    <div class="client">${esc(d.client)}</div>
    <div class="period">Período: ${period}</div>
    <div class="kpis">
      <div class="kpi"><div class="v">${Number(d.stats.totalItems).toLocaleString('es-MX')}</div><div class="l">Total prendas</div></div>
      <div class="kpi"><div class="v">${Number(d.stats.totalWashCount).toLocaleString('es-MX')}</div><div class="l">Lavados totales</div></div>
      <div class="kpi dim"><div class="v">${d.stats.overallAvg}</div><div class="l">Prom. lavados</div></div>
      <div class="kpi dim"><div class="v">${Number(d.stats.currentlyOut).toLocaleString('es-MX')}</div><div class="l">En lavandería</div></div>
      ${d.stats.damagedCount > 0 ? `<div class="kpi red"><div class="v">${d.stats.damagedCount}</div><div class="l">Dañadas</div></div>` : ''}
    </div>
  </div>
  <div class="footer">ON Sistema de Inventario RFID · Reporte generado automáticamente · Confidencial</div>
</div>

<!-- Slide 2: Article breakdown -->
<div class="slide">
  <div class="wm">ON SYS</div>
  <div class="sec">Desglose por artículo — inventario total</div>
  <div class="s2-body">
    <div style="overflow:auto">
      <table class="tbl">
        <thead><tr><th>Artículo</th><th class="num">Prendas</th><th class="num">Lavados</th><th class="num">Promedio</th></tr></thead>
        <tbody>${artRows || '<tr><td colspan="4" style="color:var(--t3);padding-top:12px">Sin artículos registrados</td></tr>'}</tbody>
      </table>
    </div>
    <div class="chart-box"><canvas id="artChart"></canvas></div>
  </div>
</div>

<!-- Slide 3: Activity -->
<div class="slide">
