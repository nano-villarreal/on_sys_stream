        // Populate article selector
        (data.articles || []).forEach(art => {
            const o = document.createElement('option');
            o.value = o.textContent = art;
            artSel.appendChild(o);
        });

        // Ordered status list — deterministic column order
        const STATUS_ORDER = ['Entregado', 'Recoleccion', 'Conteo de Bodega', 'Reprocesado', 'Sin actualizacion'];
        const activeCols = STATUS_ORDER.filter(s => (data.statuses || []).includes(s));

        function snapshotForOffset(offset) {
            if (offset === 0) return data.current;
            const d = new Date();
            d.setDate(d.getDate() + offset);
            const key = d.toISOString().slice(0, 10);
            const entry = (data.history || []).find(h => h.date === key);
            return entry ? entry.snapshot : null;
        }

        function dateLabel(offset) {
            if (offset === 0) return 'Hoy';
            if (offset === -1) return 'Ayer';
            const d = new Date();
            d.setDate(d.getDate() + offset);
            return d.toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
        }

        function renderTable(snap) {
            if (!snap) {
                tableEl.innerHTML = `<tr><td colspan="99" style="padding:20px;text-align:center;color:var(--text-3);font-size:13px">Sin datos registrados para este día</td></tr>`;
                return;
