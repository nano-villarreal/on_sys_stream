            const arts = data.articles || [];
            // header
            let h = `<thead><tr style="border-bottom:1px solid var(--border)">
                <th style="padding:8px 12px;text-align:left;font-size:11px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.5px">Artículo</th>
                <th style="padding:8px 12px;text-align:right;font-size:11px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.5px">Total</th>`;
            activeCols.forEach(s => {
                const m = STATUS_META[s] || { label: s, color: '#9ca3af' };
                h += `<th style="padding:8px 12px;text-align:right;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:${m.color}">${m.label}</th>`;
            });
            h += '</tr></thead><tbody>';
            // rows
            arts.forEach((art, i) => {
                const artData = snap[art] || {};
                const total = Object.values(artData).reduce((s, v) => s + v, 0);
                h += `<tr style="${i % 2 ? 'background:rgba(255,255,255,0.02)' : ''}">`;
                h += `<td style="padding:9px 12px;font-weight:600;color:var(--text)">${art}</td>`;
                h += `<td style="padding:9px 12px;text-align:right;color:var(--text-2);font-weight:500">${total}</td>`;
                activeCols.forEach(s => {
                    const cnt = artData[s] || 0;
                    const m   = STATUS_META[s] || { color: 'var(--text)' };
                    const pct = total > 0 ? Math.round(cnt / total * 100) : 0;
                    const bar = total > 0 ? `<div style="height:3px;border-radius:2px;background:${m.color};width:${pct}%;margin-top:3px;opacity:.7"></div>` : '';
                    h += `<td style="padding:9px 12px;text-align:right">
                        <span style="font-weight:600;color:${cnt > 0 ? m.color : 'var(--text-3)'}">${cnt > 0 ? cnt : '—'}</span>
