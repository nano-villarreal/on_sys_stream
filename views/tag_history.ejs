<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ON Sistema — Historial de Tag</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:#0e1117;--surface:#161b22;--surface-2:#1c2333;--border:rgba(255,255,255,0.07);
            --border-focus:rgba(62,207,142,0.35);--green:#3ecf8e;--green-dim:rgba(62,207,142,0.10);
            --green-glow:rgba(62,207,142,0.22);--blue:#3b82f6;--blue-dim:rgba(59,130,246,0.10);
            --red:#ef4444;--red-dim:rgba(239,68,68,0.10);--amber:#f59e0b;
            --text:#ededef;--text-2:#8b8fa8;--text-3:#4a4f62;--radius:13px;
        }
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:28px 20px;padding-top:92px;background-image:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(62,207,142,0.05) 0%,transparent 100%);}
        .navbar{position:fixed;top:0;left:0;right:0;height:64px;background:rgba(14,17,23,0.80);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;z-index:1000;}
        .brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
        .nav-logo{width:34px;height:34px;background:linear-gradient(135deg,var(--green),#22c55e);border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#0a1008;box-shadow:0 0 18px var(--green-glow);flex-shrink:0;}
        .brand-text{display:flex;flex-direction:column;gap:1px;}
        .brand-name{font-size:14px;font-weight:700;color:var(--text);letter-spacing:-0.3px;line-height:1;}
        .brand-sub{font-size:10px;font-weight:500;color:var(--text-3);letter-spacing:0.4px;text-transform:uppercase;}
        .nav-links{display:flex;gap:6px;align-items:center;}
        .nav-link{padding:6px 14px;font-size:13px;font-weight:500;text-decoration:none;border-radius:8px;border:1px solid transparent;color:var(--text-2);transition:all 0.15s;}
        .nav-link:hover{background:var(--surface);color:var(--text);border-color:var(--border);}
        .nav-link.active{background:var(--green-dim);color:var(--green);border-color:rgba(62,207,142,0.18);}
        .container{max-width:860px;margin:0 auto;}
        .page-header{text-align:center;margin-bottom:28px;animation:fadeUp 0.4s ease both;}
        .page-title{font-size:32px;font-weight:800;letter-spacing:-1.2px;margin-bottom:8px;background:linear-gradient(135deg,#fff 20%,var(--green) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
        .page-subtitle{font-size:14px;color:var(--text-2);}
        .card{background:rgba(22,27,34,0.75);border:1px solid var(--border);border-radius:18px;padding:24px;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);}
        .card+.card{margin-top:14px;}
        .card-header{display:flex;align-items:center;gap:8px;margin-bottom:18px;}
        .card-title{font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.8px;}
        .search-row{display:flex;gap:10px;}
        input[type="text"]{flex:1;padding:11px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-family:'Inter',sans-serif;font-size:14px;color:var(--text);transition:border-color 0.2s,box-shadow 0.2s;caret-color:var(--green);font-family:monospace;}
        input[type="text"]::placeholder{color:var(--text-3);font-family:'Inter',sans-serif;}
        input[type="text"]:focus{outline:none;border-color:var(--border-focus);box-shadow:0 0 0 3px rgba(62,207,142,0.07);}
        .btn-search{padding:11px 22px;font-size:13px;font-weight:700;background:var(--green);color:#091a12;border:none;border-radius:var(--radius);cursor:pointer;box-shadow:0 4px 14px var(--green-glow);transition:all 0.15s;white-space:nowrap;}
        .btn-search:hover{background:#4ddfaa;transform:translateY(-1px);}
        .tag-meta{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:4px;}
        .meta-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;}
        .meta-label{font-size:10px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:5px;}
        .meta-value{font-size:15px;font-weight:700;color:var(--text);}
        .meta-value.mono{font-family:monospace;font-size:11px;color:var(--green);word-break:break-all;}
        .status-pill{display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;}
        .s-entregado{background:var(--green-dim);color:var(--green);}
        .s-recoleccion{background:var(--blue-dim);color:var(--blue);}
        .s-default{background:var(--surface-2);color:var(--text-3);}
        .timeline{display:flex;flex-direction:column;gap:10px;}
        .event{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;gap:14px;align-items:flex-start;transition:border-color 0.2s;}
        .event:hover{border-color:rgba(255,255,255,0.12);}
        .event.recoleccion{border-left:3px solid var(--blue);}
        .event.entrega{border-left:3px solid var(--green);}
        .event.damage{border-left:3px solid var(--red);}
        .event-icon{width:32px;height:32px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;}
        .event.recoleccion .event-icon{background:var(--blue-dim);color:var(--blue);}
        .event.entrega .event-icon{background:var(--green-dim);color:var(--green);}
        .event.damage .event-icon{background:var(--red-dim);color:var(--red);}
        .event-body{flex:1;}
        .event-type{font-size:13px;font-weight:700;}
        .event.recoleccion .event-type{color:var(--blue);}
        .event.entrega .event-type{color:var(--green);}
        .event.damage .event-type{color:var(--red);}
        .event-date{font-size:11px;color:var(--text-3);margin-top:3px;}
        .event-desc{font-size:13px;color:var(--text-2);margin-top:6px;line-height:1.5;}
        .damage-img{max-width:160px;margin-top:8px;border-radius:8px;border:1px solid var(--border);}
        .alert-error{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);color:#f87171;border-radius:var(--radius);padding:14px 18px;font-size:13px;}
        .not-found{background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);border-radius:var(--radius);padding:16px 20px;font-size:13px;color:#f87171;}
        .empty-state{text-align:center;padding:40px 0;font-size:13px;color:var(--text-3);}
        @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
        .nav-toggle{display:none;background:none;border:1px solid var(--border);border-radius:8px;padding:7px 9px;cursor:pointer;color:var(--text-2);flex-direction:column;gap:4px;transition:background 0.15s,color 0.15s;flex-shrink:0;}
        .nav-toggle:hover{background:var(--surface);color:var(--text);}
        .nav-toggle span{display:block;width:18px;height:1.5px;background:currentColor;border-radius:2px;transition:transform 0.22s ease,opacity 0.15s;}
        .nav-toggle.open span:nth-child(1){transform:translateY(5.5px) rotate(45deg);}
        .nav-toggle.open span:nth-child(2){opacity:0;transform:scaleX(0);}
        .nav-toggle.open span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg);}
        @media(max-width:780px){.nav-toggle{display:flex;}.nav-links{display:none;position:fixed;top:64px;left:0;right:0;background:rgba(10,13,18,0.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:10px 16px 16px;flex-direction:column;gap:4px;z-index:999;}.nav-links.open{display:flex;animation:slideDown 0.18s ease;}.nav-link{padding:10px 14px;width:100%;}}
        @keyframes slideDown{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
    </style>
</head>
<body>
<nav class="navbar">
    <a class="brand" href="/"><div class="nav-logo">ON</div><div class="brand-text"><span class="brand-name">Sistema de Inventario</span><span class="brand-sub">Historial de Tag</span></div></a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <div class="nav-links" id="navLinks">
        <a class="nav-link" href="/">Conteo en Vivo</a>
        <a class="nav-link" href="/dar-de-alta">Dar de Alta</a>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/compare">Comparar</a>
        <a class="nav-link" href="/batch-status">Corrector</a>
        <a class="nav-link active" href="/tag-history">Historial Tag</a>
        <a class="nav-link" href="/logout" style="color:var(--text-3);">Salir</a>
    </div>
</nav>

<div class="container">
    <div class="page-header">
        <h1 class="page-title">Historial de Tag</h1>
        <p class="page-subtitle">Ciclo de vida completo de una prenda — recolecciones, entregas y daños</p>
    </div>

    <!-- Search -->
    <div class="card" style="animation:fadeUp 0.4s ease both;">
        <div class="card-header"><span class="card-title">Buscar EPC</span></div>
        <form method="GET" action="/tag-history">
            <div class="search-row">
                <input type="text" name="epc" value="<%= epc || '' %>" placeholder="24 caracteres hexadecimales" maxlength="24" autofocus />
                <button type="submit" class="btn-search">Buscar →</button>
            </div>
        </form>
    </div>

    <% if (error) { %>
        <div class="alert-error" style="margin-top:14px;"><%= error %></div>
    <% } %>

    <% if (epc && !tag && !error) { %>
        <div class="not-found" style="margin-top:14px;">Tag <strong><%= epc %></strong> no encontrado en la base de datos.</div>
    <% } %>

    <% if (tag) { %>
    <!-- Tag meta -->
    <div class="card" style="animation:fadeUp 0.4s 0.05s ease both;margin-top:14px;">
        <div class="card-header"><span class="card-title">Información del tag</span></div>
        <div class="tag-meta">
            <div class="meta-item"><div class="meta-label">EPC</div><div class="meta-value mono"><%= tag.scanId %></div></div>
            <div class="meta-item"><div class="meta-label">Artículo</div><div class="meta-value"><%= tag.article || '—' %></div></div>
            <div class="meta-item"><div class="meta-label">Cliente</div><div class="meta-value"><%= tag.client || '—' %></div></div>
            <div class="meta-item"><div class="meta-label">Lavados</div><div class="meta-value" style="color:var(--green);"><%= tag.wash_count || 0 %></div></div>
            <div class="meta-item">
                <div class="meta-label">Estado</div>
                <div class="meta-value">
                    <span class="status-pill <%= tag.status === 'Entregado' ? 's-entregado' : tag.status === 'Recoleccion' ? 's-recoleccion' : 's-default' %>">
                        <%= tag.status || 'Sin actualizacion' %>
                    </span>
                </div>
            </div>
            <div class="meta-item"><div class="meta-label">Última vista</div><div class="meta-value" style="font-size:13px;"><%= tag.last_seen ? new Date(tag.last_seen).toLocaleDateString('es-MX',{year:'numeric',month:'short',day:'numeric'}) : '—' %></div></div>
        </div>
    </div>

    <!-- Timeline -->
    <div class="card" style="animation:fadeUp 0.4s 0.09s ease both;margin-top:14px;">
        <div class="card-header"><span class="card-title">Historial de movimientos (<%= events.length + damages.length %>)</span></div>
        <% const allItems = [
            ...events.map(e => ({ ...e, itemType: e.type })),
            ...damages.map(d => ({ ...d, itemType: 'damage', typeLabel: 'Daño Reportado', type: 'damage' }))
        ].sort((a,b) => new Date(b.date) - new Date(a.date)); %>
        <% if (allItems.length === 0) { %>
            <div class="empty-state">Sin movimientos registrados.</div>
        <% } else { %>
        <div class="timeline">
            <% allItems.forEach(item => { %>
            <div class="event <%= item.type %>">
                <div class="event-icon">
                    <%= item.type === 'recoleccion' ? '↓' : item.type === 'entrega' ? '↑' : '⚠' %>
                </div>
                <div class="event-body">
                    <div class="event-type"><%= item.typeLabel %></div>
                    <div class="event-date">
                        <%= new Date(item.date).toLocaleDateString('es-MX',{year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                    </div>
                    <% if (item.itemType !== 'damage' && item.articles) { %>
                    <div class="event-desc">
                        <% Object.entries(item.articles || {}).forEach(([a,c]) => { %>
                        <span style="margin-right:8px;"><strong><%= c %></strong> <%= a %></span>
                        <% }) %>
                    </div>
                    <% } %>
                    <% if (item.itemType === 'damage') { %>
                        <div class="event-desc"><%= item.description %></div>
                        <% if (item.imageUrl) { %><img class="damage-img" src="<%= item.imageUrl %>" alt="Daño" /><% } %>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>
    </div>
    <% } %>
</div>

<script>
const t=document.getElementById('navToggle'),n=document.getElementById('navLinks');
t.addEventListener('click',()=>{t.classList.toggle('open');n.classList.toggle('open');});
n.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',()=>{t.classList.remove('open');n.classList.remove('open');}));
</script>
</body>
</html>
