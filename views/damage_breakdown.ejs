<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ON Sistema — Daños · <%= client || '' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg:           #0e1117;
            --surface:      #161b22;
            --surface-2:    #1c2333;
            --border:       rgba(255,255,255,0.07);
            --green:        #3ecf8e;
            --green-dim:    rgba(62,207,142,0.10);
            --green-glow:   rgba(62,207,142,0.22);
            --red:          #ef4444;
            --red-dim:      rgba(239,68,68,0.10);
            --amber:        #f59e0b;
            --amber-dim:    rgba(245,158,11,0.10);
            --text:         #ededef;
            --text-2:       #8b8fa8;
            --text-3:       #4a4f62;
            --radius:       13px;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg); color: var(--text);
            min-height: 100vh; padding: 28px 20px; padding-top: 92px;
            background-image: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(239,68,68,0.05) 0%, transparent 100%);
        }

        /* ── Navbar ── */
        .navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 64px;
            background: rgba(14,17,23,0.80);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 28px; z-index: 1000;
        }
        .brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .nav-logo {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--green), #22c55e);
            border-radius: 9px; display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 13px; color: #0a1008;
            box-shadow: 0 0 18px var(--green-glow); flex-shrink: 0;
        }
        .brand-text { display: flex; flex-direction: column; gap: 1px; }
        .brand-name { font-size: 14px; font-weight: 700; color: var(--text); letter-spacing: -0.3px; line-height: 1; }
        .brand-sub  { font-size: 10px; font-weight: 500; color: var(--text-3); letter-spacing: 0.4px; text-transform: uppercase; }
        .nav-links  { display: flex; gap: 6px; align-items: center; }
        .nav-link {
            padding: 6px 14px; font-size: 13px; font-weight: 500;
            text-decoration: none; border-radius: 8px; border: 1px solid transparent;
            color: var(--text-2); transition: all 0.15s;
        }
        .nav-link:hover { background: var(--surface); color: var(--text); border-color: var(--border); }
        .nav-link.active { background: var(--red-dim); color: var(--red); border-color: rgba(239,68,68,0.18); }

        /* ── Layout ── */
        .container { max-width: 1080px; margin: 0 auto; }

        .page-header { text-align: center; margin-bottom: 28px; animation: fadeUp 0.4s ease both; }
        .page-title {
            font-size: 32px; font-weight: 800; letter-spacing: -1.2px; margin-bottom: 8px;
            background: linear-gradient(135deg, #fff 20%, var(--red) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .page-subtitle { font-size: 14px; color: var(--text-2); }

        /* ── Cards ── */
        .card {
            background: rgba(22,27,34,0.75); border: 1px solid var(--border);
            border-radius: 18px; padding: 24px;
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        }
        .card + .card { margin-top: 14px; }
        .card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 18px; }
        .card-title { font-size: 12px; font-weight: 600; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.8px; }

        /* ── Client badge ── */
        .client-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: var(--red-dim); border: 1px solid rgba(239,68,68,0.18);
            border-radius: 20px; padding: 4px 14px 4px 10px;
            font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 20px;
        }
        .client-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--red); }

        /* ── Stat card ── */
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 20px 16px; text-align: center;
            max-width: 240px;
        }
        .stat-value { font-size: 48px; font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 6px; color: var(--red); }
        .stat-label { font-size: 11px; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.7px; }

        /* ── Article breakdown ── */
        .breakdown-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px;
        }

        .breakdown-item {
            background: var(--surface); border: 1px solid var(--border);
            border-left: 3px solid var(--amber);
            border-radius: var(--radius); padding: 14px 16px;
            display: flex; justify-content: space-between; align-items: center;
        }

        .breakdown-article { font-size: 13px; font-weight: 600; color: var(--text); }

        .breakdown-count {
            font-size: 13px; font-weight: 700; color: var(--amber);
            background: var(--amber-dim); border: 1px solid rgba(245,158,11,0.18);
            border-radius: 8px; padding: 2px 10px;
        }

        /* ── Damage cards grid ── */
        .damage-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px;
        }

        .damage-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden; transition: border-color 0.2s;
        }
        .damage-card:hover { border-color: rgba(239,68,68,0.3); }

        .damage-img {
            width: 100%; height: 200px; object-fit: cover;
            border-bottom: 1px solid var(--border); display: block;
        }

        .damage-no-img {
            width: 100%; height: 200px;
            background: var(--surface-2);
            display: flex; align-items: center; justify-content: center;
            color: var(--text-3); font-size: 13px;
            border-bottom: 1px solid var(--border);
        }

        .damage-info { padding: 14px 16px; }

        .damage-epc {
            font-size: 11px; font-family: 'JetBrains Mono', 'Courier New', monospace;
            color: var(--red); font-weight: 600; margin-bottom: 6px;
            word-break: break-all;
        }

        .damage-date { font-size: 11px; color: var(--text-3); margin-bottom: 8px; }

        .damage-desc { font-size: 13px; color: var(--text-2); line-height: 1.5; }

        /* ── Alert / empty ── */
        .alert-error {
            background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
            color: #f87171; border-radius: var(--radius); padding: 14px 18px; font-size: 13px;
        }
        .success-state {
            text-align: center; padding: 48px 24px;
            font-size: 15px; color: var(--green);
        }
        .success-icon { font-size: 36px; display: block; margin-bottom: 12px; }
        .empty-state { text-align: center; padding: 48px 0; font-size: 14px; color: var(--text-3); }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .nav-toggle { display: none; background: none; border: 1px solid var(--border); border-radius: 8px; padding: 7px 9px; cursor: pointer; color: var(--text-2); flex-direction: column; gap: 4px; transition: background 0.15s, color 0.15s; flex-shrink: 0; }
        .nav-toggle:hover { background: var(--surface); color: var(--text); }
        .nav-toggle span { display: block; width: 18px; height: 1.5px; background: currentColor; border-radius: 2px; transition: transform 0.22s ease, opacity 0.15s; }
        .nav-toggle.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
        .nav-toggle.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
        .nav-toggle.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }
        @media (max-width: 780px) {
            .nav-toggle { display: flex; }
            .nav-links { display: none; position: fixed; top: 64px; left: 0; right: 0; background: rgba(10,13,18,0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); padding: 10px 16px 16px; flex-direction: column; gap: 4px; z-index: 999; }
            .nav-links.open { display: flex; animation: slideDown 0.18s ease; }
            .nav-link { padding: 10px 14px; width: 100%; }
        }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="brand" href="/">
            <div class="nav-logo">ON</div>
            <div class="brand-text">
                <span class="brand-name">Sistema de Inventario</span>
                <span class="brand-sub">Desglose de Daños</span>
            </div>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="navLinks">
            <a class="nav-link" href="/">Conteo en Vivo</a>
            <a class="nav-link" href="/dar-de-alta">Dar de Alta</a>
            <a class="nav-link" href="/dashboard?client=<%= encodeURIComponent(client || '') %>">Dashboard</a>
            <a class="nav-link" href="/log?client=<%= encodeURIComponent(client || '') %>">Bitácora</a>
            <a class="nav-link" href="/compare">Comparar</a>
            <a class="nav-link" href="/create_defect">Reportar Daño</a>
            <a class="nav-link active" href="/damage-breakdown?client=<%= encodeURIComponent(client || '') %>">Daños</a>
            <a class="nav-link" href="/logout" style="color:var(--text-3);">Salir</a>
        </div>
    </nav>

    <div class="container">

        <div class="page-header">
            <h1 class="page-title">Desglose de Daños</h1>
            <p class="page-subtitle">Prendas dañadas reportadas por cliente</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert-error"><%= error %></div>

        <% } else if (typeof totalDamaged !== 'undefined' && totalDamaged === 0) { %>
            <div class="card" style="animation: fadeUp 0.4s ease both;">
                <div class="success-state">
                    <span class="success-icon">✓</span>
                    Sin prendas dañadas reportadas para <strong><%= client %></strong>
                </div>
            </div>

        <% } else if (typeof damageReports !== 'undefined') { %>

            <!-- Summary stat -->
            <div class="card" style="animation: fadeUp 0.4s ease both;">
                <div class="client-badge">
                    <span class="client-dot"></span>
                    <%= client %>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= totalDamaged %></div>
                    <div class="stat-label">Prendas Dañadas</div>
                </div>
            </div>

            <!-- Breakdown by article -->
            <% if (typeof articleBreakdown !== 'undefined' && articleBreakdown.length > 0) { %>
            <div class="card" style="animation: fadeUp 0.4s 0.05s ease both;">
                <div class="card-header"><span class="card-title">Daños por artículo</span></div>
                <div class="breakdown-grid">
                    <% articleBreakdown.forEach(([article, count]) => { %>
                    <div class="breakdown-item">
                        <span class="breakdown-article"><%= article %></span>
                        <span class="breakdown-count"><%= count %> dañada<%= count > 1 ? 's' : '' %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% } %>

            <!-- Individual damage reports -->
            <div class="card" style="animation: fadeUp 0.4s 0.10s ease both;">
                <div class="card-header"><span class="card-title">Reportes detallados</span></div>
                <% if (damageReports.length === 0) { %>
                    <div class="empty-state">No hay reportes detallados disponibles.</div>
                <% } else { %>
                <div class="damage-grid">
                    <% damageReports.forEach(report => { %>
                    <div class="damage-card">
                        <% if (report.imageUrl) { %>
                            <img class="damage-img" src="<%= report.imageUrl %>" alt="Daño en <%= report.epc %>" />
                        <% } else { %>
                            <div class="damage-no-img">Sin imagen</div>
                        <% } %>
                        <div class="damage-info">
                            <div class="damage-epc"><%= report.epc %></div>
                            <div class="damage-date">
                                <%= new Date(report.date).toLocaleDateString('es-MX', {
                                    year: 'numeric', month: 'short', day: 'numeric',
                                    hour: '2-digit', minute: '2-digit'
                                }) %>
                            </div>
                            <div class="damage-desc"><%= report.description %></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </div>

        <% } %>

    </div>
    <script>
        const t = document.getElementById('navToggle'), n = document.getElementById('navLinks');
        t.addEventListener('click', () => { t.classList.toggle('open'); n.classList.toggle('open'); });
        n.querySelectorAll('.nav-link').forEach(l => l.addEventListener('click', () => { t.classList.remove('open'); n.classList.remove('open'); }));
    </script>
</body>
</html>
