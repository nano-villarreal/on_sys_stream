<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ON Sistema — Corrector de Estado</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root{--bg:#0e1117;--surface:#161b22;--border:rgba(255,255,255,0.07);--border-focus:rgba(62,207,142,0.35);--green:#3ecf8e;--green-dim:rgba(62,207,142,0.10);--green-glow:rgba(62,207,142,0.22);--red:#ef4444;--red-dim:rgba(239,68,68,0.10);--amber:#f59e0b;--text:#ededef;--text-2:#8b8fa8;--text-3:#4a4f62;--radius:13px;}
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:28px 20px;padding-top:92px;background-image:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(62,207,142,0.05) 0%,transparent 100%);}
        .navbar{position:fixed;top:0;left:0;right:0;height:64px;background:rgba(14,17,23,0.80);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px;z-index:1000;}
        .brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
        .nav-logo{width:34px;height:34px;background:linear-gradient(135deg,var(--green),#22c55e);border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#0a1008;box-shadow:0 0 18px var(--green-glow);flex-shrink:0;}
        .brand-text{display:flex;flex-direction:column;gap:1px;}
        .brand-name{font-size:14px;font-weight:700;color:var(--text);letter-spacing:-0.3px;line-height:1;}
        .brand-sub{font-size:10px;font-weight:500;color:var(--text-3);letter-spacing:0.4px;text-transform:uppercase;}
        .nav-links{display:flex;gap:6px;align-items:center;}
        .nav-link{padding:6px 14px;font-size:13px;font-weight:500;text-decoration:none;border-radius:8px;border:1px solid transparent;color:var(--text-2);transition:all 0.15s;}
        .nav-link:hover{background:var(--surface);color:var(--text);border-color:var(--border);}
        .nav-link.active{background:var(--green-dim);color:var(--green);border-color:rgba(62,207,142,0.18);}
        .container{max-width:560px;margin:0 auto;}
        .page-header{text-align:center;margin-bottom:28px;animation:fadeUp 0.4s ease both;}
        .page-title{font-size:32px;font-weight:800;letter-spacing:-1.2px;margin-bottom:8px;background:linear-gradient(135deg,#fff 20%,var(--green) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
        .page-subtitle{font-size:14px;color:var(--text-2);}
        .card{background:rgba(22,27,34,0.75);border:1px solid var(--border);border-radius:18px;padding:28px;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);animation:fadeUp 0.4s ease both;}
        .card+.card{margin-top:14px;}
        .field-label{display:block;font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;}
        .field-label.required::after{content:' *';color:var(--red);}
        textarea{width:100%;padding:12px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-family:monospace;font-size:13px;color:var(--text);resize:vertical;min-height:140px;line-height:1.6;caret-color:var(--green);transition:border-color 0.2s,box-shadow 0.2s;}
        textarea:focus{outline:none;border-color:var(--border-focus);box-shadow:0 0 0 3px rgba(62,207,142,0.07);}
        .form-group{margin-bottom:20px;}
        .status-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
        .status-option{position:relative;}
        .status-option input{position:absolute;opacity:0;width:0;height:0;}
        .status-label{display:block;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);font-size:13px;font-weight:500;color:var(--text-2);cursor:pointer;transition:all 0.15s;text-align:center;}
        .status-label:hover{border-color:rgba(255,255,255,0.12);color:var(--text);}
        .status-option input:checked+.status-label{border-color:var(--green);color:var(--green);background:var(--green-dim);}
        .btn-submit{width:100%;padding:13px;font-size:14px;font-weight:700;background:var(--green);color:#091a12;border:none;border-radius:var(--radius);cursor:pointer;box-shadow:0 4px 16px var(--green-glow);transition:all 0.15s;}
        .btn-submit:hover{background:#4ddfaa;transform:translateY(-1px);}
        .btn-submit:disabled{opacity:0.5;cursor:not-allowed;transform:none;}
        .result-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;}
        .result-stat{display:flex;justify-content:space-between;font-size:13px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.04);}
        .result-stat:last-child{border-bottom:none;}
        .result-stat span:last-child{font-weight:700;color:var(--green);}
        .alert-error{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);color:#f87171;border-radius:var(--radius);padding:14px 18px;font-size:13px;margin-top:14px;}
        .toast{position:fixed;bottom:24px;right:24px;background:#1c2a1c;border:1px solid rgba(62,207,142,0.25);border-radius:12px;padding:14px 20px;font-size:13px;font-weight:600;color:var(--green);animation:slideIn 0.3s ease;z-index:9999;max-width:320px;}
        @keyframes slideIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
        @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
        .nav-toggle{display:none;background:none;border:1px solid var(--border);border-radius:8px;padding:7px 9px;cursor:pointer;color:var(--text-2);flex-direction:column;gap:4px;transition:background 0.15s,color 0.15s;flex-shrink:0;}
        .nav-toggle:hover{background:var(--surface);color:var(--text);}
        .nav-toggle span{display:block;width:18px;height:1.5px;background:currentColor;border-radius:2px;transition:transform 0.22s ease,opacity 0.15s;}
        .nav-toggle.open span:nth-child(1){transform:translateY(5.5px) rotate(45deg);}
        .nav-toggle.open span:nth-child(2){opacity:0;transform:scaleX(0);}
        .nav-toggle.open span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg);}
        @media(max-width:780px){.nav-toggle{display:flex;}.nav-links{display:none;position:fixed;top:64px;left:0;right:0;background:rgba(10,13,18,0.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:10px 16px 16px;flex-direction:column;gap:4px;z-index:999;}.nav-links.open{display:flex;animation:slideDown 0.18s ease;}.nav-link{padding:10px 14px;width:100%;}}
        @keyframes slideDown{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
    </style>
</head>
<body>
<nav class="navbar">
    <a class="brand" href="/"><div class="nav-logo">ON</div><div class="brand-text"><span class="brand-name">Sistema de Inventario</span><span class="brand-sub">Corrector de Estado</span></div></a>
    <button class="nav-toggle" id="navToggle"><span></span><span></span><span></span></button>
    <div class="nav-links" id="navLinks">
        <a class="nav-link" href="/">Conteo en Vivo</a>
        <a class="nav-link" href="/dar-de-alta">Dar de Alta</a>
        <a class="nav-link" href="/dashboard">Dashboard</a>
        <a class="nav-link" href="/compare">Comparar</a>
        <a class="nav-link" href="/tag-history">Historial Tag</a>
        <a class="nav-link active" href="/batch-status">Corrector</a>
        <a class="nav-link" href="/logout" style="color:var(--text-3);">Salir</a>
    </div>
</nav>

<div class="container">
    <div class="page-header">
        <h1 class="page-title">Corrector de Estado</h1>
        <p class="page-subtitle">Fuerza el estado de un grupo de EPCs cuando el sistema está desincronizado.</p>
    </div>

    <div class="card">
        <div class="form-group">
            <label class="field-label required">EPCs (uno por línea o separados por coma)</label>
            <textarea id="epcInput" placeholder="A1B2C3D4E5F6A1B2C3D4E5F6&#10;B2C3D4E5F6A1B2C3D4E5F6A1&#10;…"></textarea>
        </div>
        <div class="form-group">
            <label class="field-label required">Nuevo estado</label>
            <div class="status-grid">
                <div class="status-option"><input type="radio" name="status" id="s1" value="Sin actualizacion" /><label class="status-label" for="s1">Sin actualización</label></div>
                <div class="status-option"><input type="radio" name="status" id="s2" value="Recoleccion" /><label class="status-label" for="s2">Recolección</label></div>
                <div class="status-option"><input type="radio" name="status" id="s3" value="Entregado" checked /><label class="status-label" for="s3">Entregado</label></div>
                <div class="status-option"><input type="radio" name="status" id="s4" value="Conteo de Bodega" /><label class="status-label" for="s4">Conteo de Bodega</label></div>
                <div class="status-option" style="grid-column:1/-1;"><input type="radio" name="status" id="s5" value="Reprocesado" /><label class="status-label" for="s5">Reprocesado</label></div>
            </div>
        </div>
        <button class="btn-submit" id="submitBtn">Aplicar cambio</button>
    </div>

    <div id="resultCard" class="card" style="display:none;margin-top:14px;">
        <div style="font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:14px;">Resultado</div>
        <div class="result-box">
            <div class="result-stat"><span>EPCs procesados</span><span id="rMatched">—</span></div>
            <div class="result-stat"><span>Registros actualizados</span><span id="rModified">—</span></div>
            <div class="result-stat"><span>Nuevo estado</span><span id="rStatus">—</span></div>
        </div>
    </div>
</div>

<script>
const EPC_RE = /^[0-9A-Fa-f]{24}$/;
function parseEPCs(text) {
    return [...new Set(text.split(/[\n,\s]+/).map(s => s.trim().toUpperCase()).filter(s => EPC_RE.test(s)))];
}

document.getElementById('submitBtn').addEventListener('click', async () => {
    const epcs = parseEPCs(document.getElementById('epcInput').value);
    const status = document.querySelector('input[name="status"]:checked')?.value;
    const btn = document.getElementById('submitBtn');

    if (!epcs.length) { showToast('Sin EPCs válidos (24 caracteres hex)', true); return; }
    if (!status) { showToast('Selecciona un estado', true); return; }

    btn.disabled = true; btn.textContent = 'Aplicando…';
    try {
        const res = await fetch('/api/batch-status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ epcs, status })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');

        document.getElementById('rMatched').textContent = data.matched;
        document.getElementById('rModified').textContent = data.modified;
        document.getElementById('rStatus').textContent = status;
        document.getElementById('resultCard').style.display = 'block';
        showToast(`${data.modified} tags actualizados → ${status}`);
    } catch (e) {
        showToast(e.message, true);
    } finally {
        btn.disabled = false; btn.textContent = 'Aplicar cambio';
    }
});

function showToast(msg, isErr = false) {
    const t = document.createElement('div'); t.className = 'toast';
    t.style.color = isErr ? '#f87171' : 'var(--green)';
    t.style.borderColor = isErr ? 'rgba(239,68,68,0.25)' : 'rgba(62,207,142,0.25)';
    t.textContent = msg; document.body.appendChild(t);
    setTimeout(() => t.remove(), 3500);
}

const nt=document.getElementById('navToggle'),nn=document.getElementById('navLinks');
nt.addEventListener('click',()=>{nt.classList.toggle('open');nn.classList.toggle('open');});
nn.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',()=>{nt.classList.remove('open');nn.classList.remove('open');}));
</script>
</body>
</html>
